# ─────────────────────────────────────────────────────────
# MedOCR Intelligence Platform — Environment Configuration
# Copy this file to .env and fill in your actual values
# ─────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://medocr_user:medocr_pass@localhost:5432/medocr_db
SYNC_DATABASE_URL=postgresql://medocr_user:medocr_pass@localhost:5432/medocr_db

# ── Redis / Celery ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── MLflow ───────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ── LLM Provider: DeepSeek (agent layer) ──────────────────
# DeepSeek is OpenAI-compatible. Agents use these settings.
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Google Gemini (vision-OCR fallback only) ──────────────
# Used only by the LayoutLMv3 bounding-box vision fallback (DeepSeek is text-only).
# Leave as placeholder if you don't need the vision fallback.
GOOGLE_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ── Storage ───────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ── Confidence Gate ───────────────────────────────────────
CONFIDENCE_THRESHOLD=0.75

# ── App ──────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
